      "deepseek-reasoner": "DeepSeek R1 — 数学/复杂推理专用"
    },
    "defaults": {
      "temperature": 0.7,
      "max_tokens": 8192
    }
  },
  "relay": {
    "api_key": "$RELAY_API_KEY",
    "base_url": "https://api.b.ai/v1",
    "description": "Relay 中转 API — 支持 OpenAI 兼容接口的多模型中转",
    "models": {
      "gpt-4o-mini": "GPT-4o-Mini — 英文写作/翻译/快速任务",
      "deepseek-v4-flash": "DeepSeek V4 Flash — 中文研究（via Relay）",
      "claude-sonnet-4-20250514": "Claude Sonnet — 英文复杂分析/翻译",
      "claude-3-5-sonnet-20241022": "Claude 3.5 Sonnet — 高级推理",
      "gemini-2.0-flash": "Gemini 2.0-Flash — 快速任务/中文",
      "moonshot-v1-8k": "Moonshot (Kimi) — 长文档分析",
      "qwen-plus": "Qwen-Plus — 阿里通义，中文结构化",
      "glm-4-plus": "GLM-4-Plus — 智谱，结构化输出"
    },
    "defaults": {
      "temperature": 0.7,
      "max_tokens": 8192
    }
  },
  "ollama": {
    "provider": "ollama",
    "model_id": "llama3.2",
    "base_url": "http://localhost:11434",
    "temperature_range": [0.0, 2.0],
    "max_tokens": 8192,
    "cost_per_1k_input": 0.0,
    "cost_per_1k_output": 0.0,
    "region": "local",
    "enabled": false
