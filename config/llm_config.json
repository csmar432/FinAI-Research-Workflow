  "_model_ids": {
    "deepseek_flash":          "deepseek-v4-flash",
    "deepseek_pro":            "deepseek-v4-pro",
    "deepseek_r1":             "deepseek-reasoner",
    "gpt_4o_mini":           "gpt-4o-mini",
