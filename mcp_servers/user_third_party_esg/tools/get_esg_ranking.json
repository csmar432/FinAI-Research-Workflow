{
  "name": "get_esg_ranking",
  "description": "获取 ESG 评分全市场排名或行业排名。支持 A 股全市场、沪深 300、中证 500、中证 800 等范围。用于 ESG 投资选股、行业对标和 ESG 表现研究。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "market": {
        "type": "string",
        "enum": [
          "A-share",
          "CSI300",
          "CSI500",
          "CSI800",
          "all"
        ],
        "description": "市场范围",
        "default": "all"
      },
      "industry": {
        "type": "string",
        "description": "行业名称（如制造业、金融、能源）"
      },
      "year": {
        "type": "integer",
        "description": "年份（如 2023）"
      },
      "top_n": {
        "type": "integer",
        "description": "返回前 N 名",
        "default": 100
      }
    },
    "description": "获取ESG评分全市场排名或行业排名。"
  }
}