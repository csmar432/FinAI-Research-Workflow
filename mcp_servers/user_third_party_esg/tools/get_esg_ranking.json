{
  "name": "get_esg_ranking",
  "description": "获取ESG评分全市场排名或行业排名。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "market": {
        "type": "string",
        "enum": ["A-share", "CSI300", "CSI500", "CSI800", "all"],
        "default": "all",
        "description": "市场范围"
      },
      "industry": {
        "type": "string",
        "description": "行业名称（如制造业、金融）"
      },
      "year": {
        "type": "integer",
        "description": "年份"
      },
      "top_n": {
        "type": "integer",
        "default": 100,
        "description": "返回前N名"
      }
    },
    "description": "获取ESG评分全市场排名或行业排名"
  }
}
