{
  "name": "get_esg_controversy",
  "description": "查询企业 ESG 相关争议事件。覆盖环境处罚、劳动纠纷、治理违规、财务造假等负面事件，支持按严重程度筛选。用于研究 ESG 风险、企业社会责任和资本市场反应。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "stock_code": {
        "type": "string",
        "description": "股票代码（如 000001.SZ）"
      },
      "event_type": {
        "type": "string",
        "enum": [
          "environmental",
          "social",
          "governance",
          "financial",
          "all"
        ],
        "description": "事件类型",
        "default": "all"
      },
      "severity": {
        "type": "string",
        "enum": [
          "high",
          "medium",
          "low",
          "all"
        ],
        "description": "严重程度",
        "default": "all"
      },
      "start_date": {
        "type": "string",
        "description": "事件日期起（YYYY-MM-DD）"
      },
      "end_date": {
        "type": "string",
        "description": "事件日期止（YYYY-MM-DD）"
      }
    },
    "description": "查询企业ESG相关争议事件。覆盖环境处罚、劳动纠纷、治理违规、财务造假等负面事件。"
  }
}