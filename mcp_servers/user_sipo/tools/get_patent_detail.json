{
  "name": "get_patent_detail",
  "description": "获取指定专利的详细信息，包括摘要、权利要求书要点、附图说明。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "patent_number": {
        "type": "string",
        "description": "专利号（如CN202110123456.7）"
      },
      "include_claims": {
        "type": "boolean",
        "default": false,
        "description": "是否包含权利要求"
      }
    },
    "required": ["patent_number"],
    "description": "获取指定专利的详细信息"
  }
}
