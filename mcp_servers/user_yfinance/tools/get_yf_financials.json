{
  "name": "get_yf_financials",
  "description": "获取公司财务报表（利润表、资产负债表、现金流量表、比率分析）。使用 Yahoo Finance API，无需 API Key。用于财务分析、盈余管理和估值研究。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "ticker": {
        "type": "string",
        "description": "股票代码（如 AAPL、MSFT）",
        "required": true
      },
      "statement_type": {
        "type": "string",
        "enum": [
          "income",
          "balance",
          "cashflow",
          "ratios"
        ],
        "description": "报表类型",
        "default": "income"
      }
    },
    "required": [
      "ticker"
    ],
    "description": "获取公司财务报表（利润表、资产负债表、现金流量表）。使用 Yahoo Finance API，无需 API Key。"
  }
}