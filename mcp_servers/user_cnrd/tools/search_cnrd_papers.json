{
  "name": "search_cnrd_papers",
  "description": "检索 CNRDS（中国研究数据服务平台）学术论文数据库，覆盖中文核心期刊（CSSCI/CSCD）、学位论文、会议论文。用于文献计量、引文分析和研究热点识别。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "title": {
        "type": "string",
        "description": "论文标题关键词"
      },
      "author": {
        "type": "string",
        "description": "作者（支持多作者）"
      },
      "journal": {
        "type": "string",
        "description": "期刊名称"
      },
      "year_from": {
        "type": "integer",
        "description": "发表年份起（如 2018）"
      },
      "year_to": {
        "type": "integer",
        "description": "发表年份止（如 2024）"
      },
      "page": {
        "type": "integer",
        "description": "页码",
        "default": 1
      },
      "page_size": {
        "type": "integer",
        "description": "每页条数（最大100）",
        "default": 20
      }
    },
    "description": "Search parameters for 中国研究数据服务平台（CNRDS）。提供专利数据库、研究论文、上市公司数据。需注册获取API Key：https://www.cnrds.com query"
  }
}