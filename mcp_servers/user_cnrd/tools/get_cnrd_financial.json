{
  "name": "get_cnrd_financial",
  "description": "查询 CNRDS（中国研究数据服务平台）上市公司财务数据：资产负债表、利润表、现金流量表。用于财务分析、盈余管理和企业绩效研究。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "stock_code": {
        "type": "string",
        "description": "股票代码（如 600000.SH）",
        "required": true
      },
      "year": {
        "type": "integer",
        "description": "年份（如 2023）",
        "required": true
      },
      "quarter": {
        "type": "integer",
        "description": "季度（1-4，留空为年度数据）",
        "minimum": 1,
        "maximum": 4
      }
    },
    "required": [
      "stock_code",
      "year"
    ],
    "description": "查询CNRDS上市公司财务数据库。获取资产负债、利润表、现金流量数据。"
  }
}